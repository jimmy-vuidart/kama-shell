#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
APP_DIR="${KAMA_SHELL_APP_DIR:-__KAMA_SHELL_APP_DIR__}"
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
SESSION_CONFIG="${KAMA_SHELL_SESSION_CONFIG:-$CONFIG_HOME/kama-shell/session.conf}"
DEBUG_SESSION_CONFIG="${KAMA_SHELL_DEBUG_SESSION_CONFIG:-$CONFIG_HOME/kama-shell/debug-session.conf}"

if [[ "$APP_DIR" == "__KAMA_SHELL_APP_DIR__" ]]; then
    APP_DIR=$(cd -- "$SCRIPT_DIR/.." && pwd)
fi

RUNNER="$APP_DIR/run.sh"
SHELL_ENTRY="$APP_DIR/src/shell.qml"
KWIN_SCRIPTS_DIR="$APP_DIR/kwin/scripts"
KWIN_SCREENSHOT_SCRIPT_ID="kama-shell-screenshot"
KWIN_SHORTCUTS_SCRIPT_ID="kama-shell-shortcuts"
SCREENSHOT_HELPER="$APP_DIR/scripts/copy-screenshot-to-clipboard.sh"

if [[ ! -x "$RUNNER" ]]; then
    echo "Runner introuvable ou non executable: $RUNNER" >&2
    exit 1
fi

if [[ -f "$SESSION_CONFIG" ]]; then
    # User-owned session overrides shared with the regular session.
    # shellcheck disable=SC1090
    source "$SESSION_CONFIG"
fi

if [[ -f "$DEBUG_SESSION_CONFIG" ]]; then
    # User-owned overrides specific to the debug session.
    # shellcheck disable=SC1090
    source "$DEBUG_SESSION_CONFIG"
fi

KAMA_CONFIG="${KAMA_CONFIG:-$CONFIG_HOME/kama-shell/kama.conf}"

apply_keyboard_config() {
    if ! command -v kwriteconfig6 >/dev/null 2>&1; then
        return
    fi

    if [[ -z "${KAMA_XKB_LAYOUT:-}" ]] \
        && [[ -z "${KAMA_XKB_MODEL:-}" ]] \
        && [[ -z "${KAMA_XKB_VARIANT:-}" ]] \
        && [[ -z "${KAMA_XKB_OPTIONS:-}" ]]; then
        return
    fi

    kwriteconfig6 --file kxkbrc --group Layout --key Use true

    if [[ -n "${KAMA_XKB_LAYOUT:-}" ]]; then
        kwriteconfig6 --file kxkbrc --group Layout --key LayoutList "$KAMA_XKB_LAYOUT"
    fi

    if [[ -n "${KAMA_XKB_MODEL:-}" ]]; then
        kwriteconfig6 --file kxkbrc --group Layout --key Model "$KAMA_XKB_MODEL"
    fi

    if [[ -n "${KAMA_XKB_VARIANT:-}" ]]; then
        kwriteconfig6 --file kxkbrc --group Layout --key VariantList "$KAMA_XKB_VARIANT"
    fi

    if [[ -n "${KAMA_XKB_OPTIONS:-}" ]]; then
        kwriteconfig6 --file kxkbrc --group Layout --key Options "$KAMA_XKB_OPTIONS"
    fi
}

kama_config_value() {
    local section="$1"
    local key="$2"
    local fallback="$3"
    local value

    if [[ ! -f "$KAMA_CONFIG" ]] || ! command -v awk >/dev/null 2>&1; then
        printf '%s\n' "$fallback"
        return
    fi

    value=$(
        awk -F= -v wanted_section="$section" -v wanted_key="$key" '
            function trim(value) {
                sub(/^[[:space:]]+/, "", value)
                sub(/[[:space:]]+$/, "", value)
                return value
            }

            function unquote(value) {
                value = trim(value)
                if (
                    (substr(value, 1, 1) == "\"" && substr(value, length(value), 1) == "\"")
                    || (substr(value, 1, 1) == "'"'"'" && substr(value, length(value), 1) == "'"'"'")
                ) {
                    return substr(value, 2, length(value) - 2)
                }

                return value
            }

            /^[[:space:]]*($|#|;)/ { next }

            {
                line = $0
                sub(/[[:space:]]+[;#].*$/, "", line)
                line = trim(line)

                if (line ~ /^\[[^]]+\]$/) {
                    current_section = trim(substr(line, 2, length(line) - 2))
                    next
                }

                separator = index(line, "=")
                if (separator <= 0) {
                    next
                }

                current_key = trim(substr(line, 1, separator - 1))
                current_value = trim(substr(line, separator + 1))

                if (
                    (current_section == wanted_section && current_key == wanted_key)
                    || current_key == wanted_section "." wanted_key
                ) {
                    print unquote(current_value)
                    exit
                }
            }
        ' "$KAMA_CONFIG"
    )

    if [[ -n "$value" ]]; then
        printf '%s\n' "$value"
        return
    fi

    printf '%s\n' "$fallback"
}

normalize_launcher_shortcut() {
    local shortcut
    shortcut=$(printf '%s' "$1" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')

    case "${shortcut,,}" in
        "" | super | win | windows)
            printf '%s\n' "Meta"
            ;;
        *)
            printf '%s\n' "$shortcut"
            ;;
    esac
}

install_kwin_package() {
    local script_id="$1"
    local script_source="$KWIN_SCRIPTS_DIR/$script_id"
    local script_target="$DATA_HOME/kwin/scripts/$script_id"

    if [[ ! -d "$script_source" ]]; then
        return
    fi

    install -d "$script_target"
    cp -r "$script_source"/. "$script_target"/

    if command -v kwriteconfig6 >/dev/null 2>&1; then
        kwriteconfig6 --file kwinrc --group Plugins --key "${script_id}Enabled" true
    fi
}

install_kwin_script() {
    install_kwin_package "$KWIN_SCREENSHOT_SCRIPT_ID"
    install_kwin_package "$KWIN_SHORTCUTS_SCRIPT_ID"

    if ! command -v kwriteconfig6 >/dev/null 2>&1; then
        return
    fi

    if [[ -x "$SCREENSHOT_HELPER" ]]; then
        kwriteconfig6 --file kwinrc --group "Script-${KWIN_SCREENSHOT_SCRIPT_ID}" --key helperPath "$SCREENSHOT_HELPER"
    fi

    local qs_path="${KAMA_QS_PATH:-}"
    if [[ -z "$qs_path" ]]; then
        qs_path=$(command -v qs || true)
    fi
    qs_path="${qs_path:-/usr/bin/qs}"

    local launcher_shortcut
    launcher_shortcut=$(normalize_launcher_shortcut "$(kama_config_value launcher shortcut Meta)")

    kwriteconfig6 --file kwinrc --group "Script-${KWIN_SHORTCUTS_SCRIPT_ID}" --key qsPath "$qs_path"
    kwriteconfig6 --file kwinrc --group "Script-${KWIN_SHORTCUTS_SCRIPT_ID}" --key shellEntry "$SHELL_ENTRY"
    kwriteconfig6 --file kwinrc --group "Script-${KWIN_SHORTCUTS_SCRIPT_ID}" --key launcherShortcut "$launcher_shortcut"

    if [[ "$launcher_shortcut" == "Meta" ]]; then
        kwriteconfig6 \
            --file kwinrc \
            --group ModifierOnlyShortcuts \
            --key Meta \
            "org.kde.kglobalaccel,/component/kwin,org.kde.kglobalaccel.Component,invokeShortcut,KamaShellToggleLauncher"
    else
        kwriteconfig6 --file kwinrc --group ModifierOnlyShortcuts --key Meta ""
    fi
}

apply_kwin_effect_config() {
    if ! command -v kwriteconfig6 >/dev/null 2>&1; then
        return
    fi

    if [[ "${KAMA_KWIN_BLUR:-1}" != "1" ]]; then
        return
    fi

    kwriteconfig6 --file kwinrc --group Plugins --key blurEnabled true
    kwriteconfig6 --file kwinrc --group Plugins --key backgroundcontrastEnabled true
}

export XDG_CURRENT_DESKTOP=KamaShell
export XDG_SESSION_DESKTOP=kama-shell-debug
export DESKTOP_SESSION=kama-shell-debug
export KAMA_SESSION=1
export KAMA_DEV="${KAMA_DEV:-1}"
export KAMA_QS_LOG_TIMES="${KAMA_QS_LOG_TIMES:-1}"
export KAMA_QS_VERBOSE="${KAMA_QS_VERBOSE:-2}"
export KAMA_RUN_LOG_FILE="${KAMA_RUN_LOG_FILE:-$APP_DIR/logs/kama-shell.log}"
export QT_WAYLAND_SHELL_INTEGRATION=layer-shell

apply_keyboard_config
install_kwin_script
apply_kwin_effect_config

KWIN_ARGS=(
    --xwayland
    --no-lockscreen
    --desktopfile
    kama-shell-debug
    --exit-with-session
    "$RUNNER"
)

if [[ -n "${KAMA_WAYLAND_SOCKET:-}" ]]; then
    KWIN_ARGS+=(
        --socket
        "$KAMA_WAYLAND_SOCKET"
    )
fi

exec kwin_wayland "${KWIN_ARGS[@]}" "$@"
