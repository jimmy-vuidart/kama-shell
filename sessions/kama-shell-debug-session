#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
APP_DIR="${KAMA_SHELL_APP_DIR:-__KAMA_SHELL_APP_DIR__}"
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
DEBUG_SESSION_CONFIG="${KAMA_SHELL_DEBUG_SESSION_CONFIG:-$CONFIG_HOME/kama-shell/debug-session.conf}"
SESSION_BIN="$SCRIPT_DIR/kama-shell-session"

if [[ "$APP_DIR" == "__KAMA_SHELL_APP_DIR__" ]]; then
    APP_DIR=$(cd -- "$SCRIPT_DIR/.." && pwd)
fi

if [[ ! -x "$SESSION_BIN" ]]; then
    echo "Session launcher introuvable: $SESSION_BIN" >&2
    exit 1
fi

export KAMA_SHELL_APP_DIR="$APP_DIR"
export KAMA_DEV="${KAMA_DEV:-1}"
export KAMA_QS_LOG_TIMES="${KAMA_QS_LOG_TIMES:-1}"
export KAMA_QS_VERBOSE="${KAMA_QS_VERBOSE:-2}"
export KAMA_RUN_LOG_FILE="${KAMA_RUN_LOG_FILE:-$APP_DIR/logs/kama-shell.log}"

if [[ -f "$DEBUG_SESSION_CONFIG" ]]; then
    # User-owned overrides specific to the debug session.
    set -a
    # shellcheck disable=SC1090
    source "$DEBUG_SESSION_CONFIG"
    set +a
fi

exec "$SESSION_BIN" "$@"
