#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
APP_DIR="${KAMA_SHELL_APP_DIR:-__KAMA_SHELL_APP_DIR__}"
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
SESSION_CONFIG="${KAMA_SHELL_SESSION_CONFIG:-$CONFIG_HOME/kama-shell/session.conf}"
DEBUG_SESSION_CONFIG="${KAMA_SHELL_DEBUG_SESSION_CONFIG:-$CONFIG_HOME/kama-shell/debug-session.conf}"

if [[ "$APP_DIR" == "__KAMA_SHELL_APP_DIR__" ]]; then
    APP_DIR=$(cd -- "$SCRIPT_DIR/.." && pwd)
fi

RUNNER="$APP_DIR/run.sh"
KWIN_SCRIPT_ID="kama-shell-screenshot"
KWIN_SCRIPT_SOURCE="$APP_DIR/kwin/scripts/$KWIN_SCRIPT_ID"
KWIN_SCRIPT_TARGET="$DATA_HOME/kwin/scripts/$KWIN_SCRIPT_ID"
SCREENSHOT_HELPER="$APP_DIR/scripts/copy-screenshot-to-clipboard.sh"

if [[ ! -x "$RUNNER" ]]; then
    echo "Runner introuvable ou non executable: $RUNNER" >&2
    exit 1
fi

if [[ -f "$SESSION_CONFIG" ]]; then
    # User-owned session overrides shared with the regular session.
    # shellcheck disable=SC1090
    source "$SESSION_CONFIG"
fi

if [[ -f "$DEBUG_SESSION_CONFIG" ]]; then
    # User-owned overrides specific to the debug session.
    # shellcheck disable=SC1090
    source "$DEBUG_SESSION_CONFIG"
fi

apply_keyboard_config() {
    if ! command -v kwriteconfig6 >/dev/null 2>&1; then
        return
    fi

    if [[ -z "${KAMA_XKB_LAYOUT:-}" ]] \
        && [[ -z "${KAMA_XKB_MODEL:-}" ]] \
        && [[ -z "${KAMA_XKB_VARIANT:-}" ]] \
        && [[ -z "${KAMA_XKB_OPTIONS:-}" ]]; then
        return
    fi

    kwriteconfig6 --file kxkbrc --group Layout --key Use true

    if [[ -n "${KAMA_XKB_LAYOUT:-}" ]]; then
        kwriteconfig6 --file kxkbrc --group Layout --key LayoutList "$KAMA_XKB_LAYOUT"
    fi

    if [[ -n "${KAMA_XKB_MODEL:-}" ]]; then
        kwriteconfig6 --file kxkbrc --group Layout --key Model "$KAMA_XKB_MODEL"
    fi

    if [[ -n "${KAMA_XKB_VARIANT:-}" ]]; then
        kwriteconfig6 --file kxkbrc --group Layout --key VariantList "$KAMA_XKB_VARIANT"
    fi

    if [[ -n "${KAMA_XKB_OPTIONS:-}" ]]; then
        kwriteconfig6 --file kxkbrc --group Layout --key Options "$KAMA_XKB_OPTIONS"
    fi
}

install_kwin_script() {
    if [[ ! -d "$KWIN_SCRIPT_SOURCE" ]] || [[ ! -x "$SCREENSHOT_HELPER" ]]; then
        return
    fi

    install -d "$KWIN_SCRIPT_TARGET"
    cp -r "$KWIN_SCRIPT_SOURCE"/. "$KWIN_SCRIPT_TARGET"/

    if command -v kwriteconfig6 >/dev/null 2>&1; then
        kwriteconfig6 --file kwinrc --group Plugins --key "${KWIN_SCRIPT_ID}Enabled" true
        kwriteconfig6 --file kwinrc --group "Script-${KWIN_SCRIPT_ID}" --key helperPath "$SCREENSHOT_HELPER"
    fi
}

apply_kwin_effect_config() {
    if ! command -v kwriteconfig6 >/dev/null 2>&1; then
        return
    fi

    if [[ "${KAMA_KWIN_BLUR:-1}" != "1" ]]; then
        return
    fi

    kwriteconfig6 --file kwinrc --group Plugins --key blurEnabled true
    kwriteconfig6 --file kwinrc --group Plugins --key backgroundcontrastEnabled true
}

export XDG_CURRENT_DESKTOP=KamaShell
export XDG_SESSION_DESKTOP=kama-shell-debug
export DESKTOP_SESSION=kama-shell-debug
export KAMA_SESSION=1
export KAMA_DEV="${KAMA_DEV:-1}"
export KAMA_QS_LOG_TIMES="${KAMA_QS_LOG_TIMES:-1}"
export KAMA_QS_VERBOSE="${KAMA_QS_VERBOSE:-2}"
export KAMA_RUN_LOG_FILE="${KAMA_RUN_LOG_FILE:-$APP_DIR/logs/kama-shell.log}"
export QT_WAYLAND_SHELL_INTEGRATION=layer-shell

apply_keyboard_config
install_kwin_script
apply_kwin_effect_config

KWIN_ARGS=(
    --xwayland
    --no-lockscreen
    --desktopfile
    kama-shell-debug
    --exit-with-session
    "$RUNNER"
)

if [[ -n "${KAMA_WAYLAND_SOCKET:-}" ]]; then
    KWIN_ARGS+=(
        --socket
        "$KAMA_WAYLAND_SOCKET"
    )
fi

exec kwin_wayland "${KWIN_ARGS[@]}" "$@"
