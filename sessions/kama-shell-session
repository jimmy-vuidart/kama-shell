#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
APP_DIR="${KAMA_SHELL_APP_DIR:-__KAMA_SHELL_APP_DIR__}"
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
SESSION_CONFIG="${KAMA_SHELL_SESSION_CONFIG:-$CONFIG_HOME/kama-shell/session.conf}"

if [[ "$APP_DIR" == "__KAMA_SHELL_APP_DIR__" ]]; then
    APP_DIR=$(cd -- "$SCRIPT_DIR/.." && pwd)
fi

RUNNER="$APP_DIR/run.sh"
SHELL_ENTRY="$APP_DIR/src/shell.qml"
SCREENSHOT_HELPER="$APP_DIR/scripts/copy-screenshot-to-clipboard.sh"
LAUNCHER_HELPER="$APP_DIR/scripts/toggle-launcher.sh"

if [[ ! -x "$RUNNER" ]]; then
    echo "Runner introuvable ou non executable: $RUNNER" >&2
    exit 1
fi

if [[ -f "$SESSION_CONFIG" ]]; then
    # User-owned session overrides.
    # shellcheck disable=SC1090
    source "$SESSION_CONFIG"
fi

KAMA_CONFIG="${KAMA_CONFIG:-$CONFIG_HOME/kama-shell/kama.conf}"
KAMA_COMPOSITOR="${KAMA_COMPOSITOR:-niri}"

kama_config_value() {
    local section="$1"
    local key="$2"
    local fallback="$3"
    local value

    if [[ ! -f "$KAMA_CONFIG" ]] || ! command -v awk >/dev/null 2>&1; then
        printf '%s\n' "$fallback"
        return
    fi

    value=$(
        awk -F= -v wanted_section="$section" -v wanted_key="$key" '
            function trim(value) {
                sub(/^[[:space:]]+/, "", value)
                sub(/[[:space:]]+$/, "", value)
                return value
            }

            function unquote(value) {
                single_quote = sprintf("%c", 39)
                value = trim(value)
                if (((substr(value, 1, 1) == "\"" && substr(value, length(value), 1) == "\"") || (substr(value, 1, 1) == single_quote && substr(value, length(value), 1) == single_quote))) {
                    return substr(value, 2, length(value) - 2)
                }

                return value
            }

            /^[[:space:]]*($|#|;)/ { next }

            {
                line = $0
                sub(/[[:space:]]+[;#].*$/, "", line)
                line = trim(line)

                if (line ~ /^\[[^]]+\]$/) {
                    current_section = trim(substr(line, 2, length(line) - 2))
                    next
                }

                separator = index(line, "=")
                if (separator <= 0) {
                    next
                }

                current_key = trim(substr(line, 1, separator - 1))
                current_value = trim(substr(line, separator + 1))

                if (((current_section == wanted_section && current_key == wanted_key) || current_key == wanted_section "." wanted_key)) {
                    print unquote(current_value)
                    exit
                }
            }
        ' "$KAMA_CONFIG"
    )

    if [[ -n "$value" ]]; then
        printf '%s\n' "$value"
        return
    fi

    printf '%s\n' "$fallback"
}

normalize_launcher_shortcut() {
    local shortcut
    shortcut=$(printf '%s' "$1" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')

    case "${shortcut,,}" in
        "")
            printf '%s\n' "Super+Space"
            ;;
        meta | super | win | windows)
            printf '%s\n' "Super"
            ;;
        *)
            printf '%s\n' "$shortcut" | sed -E 's/(^|\+)Meta($|\+)/\1Super\2/g; s/(^|\+)Win($|\+)/\1Super\2/g'
            ;;
    esac
}

niri_launcher_shortcut() {
    local shortcut="$1"

    if [[ "$shortcut" == "Super" ]]; then
        printf '%s\n' "Super+Space"
        return
    fi

    printf '%s\n' "$shortcut"
}

labwc_launcher_shortcut() {
    local shortcut="$1"
    local result=""
    local part

    if [[ "$shortcut" == "Super" ]]; then
        printf '%s\n' "Super_L"
        return
    fi

    IFS='+' read -ra parts <<<"$shortcut"
    for part in "${parts[@]}"; do
        case "${part,,}" in
            super | win | windows | meta)
                part="W"
                ;;
            ctrl | control)
                part="C"
                ;;
            alt)
                part="A"
                ;;
            shift)
                part="S"
                ;;
        esac

        if [[ -n "$result" ]]; then
            result+="-"
        fi

        result+="$part"
    done

    printf '%s\n' "${result:-W-Space}"
}

kdl_string() {
    printf '"%s"' "$(printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g')"
}

shell_word() {
    printf '%q' "$1"
}

expand_path() {
    case "$1" in
        "~/"*)
            printf '%s/%s\n' "$HOME" "${1#"~/"}"
            ;;
        *)
            printf '%s\n' "$1"
            ;;
    esac
}

xml_attr() {
    printf '%s' "$1" \
        | sed 's/&/\&amp;/g; s/"/\&quot;/g; s/</\&lt;/g; s/>/\&gt;/g'
}

runtime_dir() {
    local base="${XDG_RUNTIME_DIR:-/tmp}"
    local dir="$base/kama-shell"

    install -d "$dir"
    printf '%s\n' "$dir"
}

niri_base_config() {
    local config_path

    if [[ -n "${KAMA_NIRI_CONFIG:-}" ]]; then
        config_path=$(expand_path "$KAMA_NIRI_CONFIG")
    fi

    if [[ -n "${config_path:-}" && -f "$config_path" ]]; then
        printf '%s\n' "$config_path"
        return
    fi

    config_path=""
    if [[ -n "${NIRI_CONFIG:-}" ]]; then
        config_path=$(expand_path "$NIRI_CONFIG")
    fi

    if [[ -n "${config_path:-}" && -f "$config_path" ]]; then
        printf '%s\n' "$config_path"
        return
    fi

    if [[ -f "$CONFIG_HOME/niri/config.kdl" ]]; then
        printf '%s\n' "$CONFIG_HOME/niri/config.kdl"
        return
    fi

    if [[ -f /etc/niri/config.kdl ]]; then
        printf '%s\n' /etc/niri/config.kdl
        return
    fi

    if [[ -f /usr/share/doc/niri/default-config.kdl ]]; then
        printf '%s\n' /usr/share/doc/niri/default-config.kdl
    fi
}

write_niri_config() {
    local output_path="$1"
    local base_config
    local filtered_base_config
    local shortcut

    base_config=$(niri_base_config)
    shortcut=$(niri_launcher_shortcut "$(normalize_launcher_shortcut "$(kama_config_value launcher shortcut Super+Space)")")

    if [[ "$base_config" == "/usr/share/doc/niri/default-config.kdl" ]]; then
        filtered_base_config="$output_path.base.kdl"
        sed '/^[[:space:]]*spawn-at-startup[[:space:]]*"waybar"[[:space:]]*$/d' "$base_config" >"$filtered_base_config"
        base_config="$filtered_base_config"
    fi

    {
        printf '%s\n' "// Generated by Kama Shell. Edit ~/.config/kama-shell/session.conf to change session options."

        if [[ -n "$base_config" && "$base_config" != "$output_path" ]]; then
            printf 'include %s\n\n' "$(kdl_string "$base_config")"
        fi

        printf 'spawn-at-startup %s\n\n' "$(kdl_string "$RUNNER")"

        if [[ -n "${KAMA_XKB_LAYOUT:-}${KAMA_XKB_MODEL:-}${KAMA_XKB_VARIANT:-}${KAMA_XKB_OPTIONS:-}" ]]; then
            printf '%s\n' "input {"
            printf '%s\n' "    keyboard {"
            printf '%s\n' "        xkb {"
            if [[ -n "${KAMA_XKB_LAYOUT:-}" ]]; then
                printf '            layout %s\n' "$(kdl_string "$KAMA_XKB_LAYOUT")"
            fi
            if [[ -n "${KAMA_XKB_MODEL:-}" ]]; then
                printf '            model %s\n' "$(kdl_string "$KAMA_XKB_MODEL")"
            fi
            if [[ -n "${KAMA_XKB_VARIANT:-}" ]]; then
                printf '            variant %s\n' "$(kdl_string "$KAMA_XKB_VARIANT")"
            fi
            if [[ -n "${KAMA_XKB_OPTIONS:-}" ]]; then
                printf '            options %s\n' "$(kdl_string "$KAMA_XKB_OPTIONS")"
            fi
            printf '%s\n' "        }"
            printf '%s\n' "    }"
            printf '%s\n\n' "}"
        fi

        printf '%s\n' "binds {"
        printf '    %s { spawn %s; }\n' "$shortcut" "$(kdl_string "$LAUNCHER_HELPER")"
        printf '%s\n' "    Print { screenshot-screen write-to-disk=false; }"
        printf '%s\n' "}"
    } >"$output_path"
}

write_labwc_config() {
    local dir="$1"
    local shortcut
    local launcher_action
    local screenshot_action

    shortcut=$(labwc_launcher_shortcut "$(normalize_launcher_shortcut "$(kama_config_value launcher shortcut Super+Space)")")
    launcher_action=$(xml_attr "$LAUNCHER_HELPER")
    screenshot_action=$(xml_attr "$SCREENSHOT_HELPER")

    install -d "$dir"

    {
        printf '%s\n' "XDG_CURRENT_DESKTOP=KamaShell"
        printf '%s\n' "XDG_SESSION_DESKTOP=kama-shell"
        printf '%s\n' "DESKTOP_SESSION=kama-shell"
        printf '%s\n' "KAMA_COMPOSITOR=labwc"
        printf '%s\n' "QT_WAYLAND_SHELL_INTEGRATION=layer-shell"
        [[ -n "${KAMA_XKB_LAYOUT:-}" ]] && printf 'XKB_DEFAULT_LAYOUT=%s\n' "$KAMA_XKB_LAYOUT"
        [[ -n "${KAMA_XKB_MODEL:-}" ]] && printf 'XKB_DEFAULT_MODEL=%s\n' "$KAMA_XKB_MODEL"
        [[ -n "${KAMA_XKB_VARIANT:-}" ]] && printf 'XKB_DEFAULT_VARIANT=%s\n' "$KAMA_XKB_VARIANT"
        [[ -n "${KAMA_XKB_OPTIONS:-}" ]] && printf 'XKB_DEFAULT_OPTIONS=%s\n' "$KAMA_XKB_OPTIONS"
    } >"$dir/environment"

    {
        printf '%s\n' "#!/bin/sh"
        printf '%s "$@" &\n' "$(shell_word "$RUNNER")"
    } >"$dir/autostart"
    chmod 755 "$dir/autostart"

    {
        printf '%s\n' '<?xml version="1.0"?>'
        printf '%s\n' '<labwc_config>'
        printf '%s\n' '  <keyboard>'
        printf '%s\n' '    <default/>'
        if [[ "$shortcut" == "Super_L" ]]; then
            printf '%s\n' '    <keybind key="Super_L" onRelease="yes">'
        else
            printf '    <keybind key="%s">\n' "$(xml_attr "$shortcut")"
        fi
        printf '      <action name="Execute" command="%s"/>\n' "$launcher_action"
        printf '%s\n' '    </keybind>'
        printf '%s\n' '    <keybind key="Print">'
        printf '      <action name="Execute" command="%s"/>\n' "$screenshot_action"
        printf '%s\n' '    </keybind>'
        printf '%s\n' '  </keyboard>'
        printf '%s\n' '</labwc_config>'
    } >"$dir/rc.xml"
}

run_niri_session() {
    local dir
    local config_path

    dir=$(runtime_dir)
    config_path="$dir/niri.kdl"
    write_niri_config "$config_path"

    export KAMA_COMPOSITOR=niri
    export NIRI_CONFIG="$config_path"

    if command -v niri-session >/dev/null 2>&1; then
        exec niri-session "$@"
    fi

    if command -v niri >/dev/null 2>&1; then
        exec niri --session "$@"
    fi

    echo "Niri introuvable. Installez niri ou definissez KAMA_COMPOSITOR=labwc." >&2
    exit 1
}

run_labwc_session() {
    local dir

    if ! command -v labwc >/dev/null 2>&1; then
        echo "labwc introuvable. Installez labwc ou definissez KAMA_COMPOSITOR=niri." >&2
        exit 1
    fi

    dir="$(runtime_dir)/labwc"
    write_labwc_config "$dir"

    export KAMA_COMPOSITOR=labwc
    exec labwc -C "$dir" "$@"
}

export XDG_CURRENT_DESKTOP=KamaShell
export XDG_SESSION_DESKTOP=kama-shell
export DESKTOP_SESSION=kama-shell
export KAMA_DEV="${KAMA_DEV:-1}"
export QT_WAYLAND_SHELL_INTEGRATION=layer-shell
export KAMA_SHELL_ENTRY="$SHELL_ENTRY"

case "${KAMA_COMPOSITOR,,}" in
    niri)
        run_niri_session "$@"
        ;;
    labwc)
        run_labwc_session "$@"
        ;;
    *)
        echo "Compositeur non supporte: $KAMA_COMPOSITOR (attendu: niri ou labwc)" >&2
        exit 1
        ;;
esac
